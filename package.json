		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^22",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
